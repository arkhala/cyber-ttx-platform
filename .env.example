# LLM Configuration (choose one primary)

# xAI / Grok (recommended for production exercises)
XAI_API_KEY=sk-...

# Local Ollama (OpenAI-compatible)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2
# Or any other OpenAI-compatible endpoint

# App
APP_ENV=development
EXERCISE_DB_PATH=exercises.db   # or leave for in-memory/JSONL default
EXPORT_DIR=exports

# Optional: rate limiting, token budgets per exercise
MAX_LLM_TOKENS_PER_EXERCISE=25000
