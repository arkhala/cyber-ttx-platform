# LLM (choose one or both; xAI preferred for quality)
XAI_API_KEY=sk-...   # get from https://console.x.ai
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# App
APP_ENV=development
DB_PATH=data/exercises.db
EXPORT_DIR=exports
MAX_TOKENS_PER_EXERCISE=30000

# Feature flags (enable as slices are ready)
ENABLE_AI_BRANCHING=true
ENABLE_CSIRT=true
ENABLE_DOCGEN=true

# From user OQ decisions
STRICT_REPRODUCIBILITY=true   # temp=0 + seeds for same choices -> same exercise
SINGLE_FACILITATOR_MVP=true   # observers via link; no concurrent edits
